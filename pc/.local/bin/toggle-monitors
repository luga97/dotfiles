#!/usr/bin/env bash
set -euo pipefail

if hyprctl monitors all | awk '
  /^Monitor DP-2 / { in_dp2 = 1 }
  /^Monitor / && $2 != "DP-2" { in_dp2 = 0 }
  in_dp2 && /mirrorOf: 0/ { found = 1 }
  END { exit(found ? 0 : 1) }
'; then
  hyprctl keyword monitor "DP-1,2560x1440@180,1920x0,1.3"
  hyprctl keyword monitor "DP-2,1920x1080@60,0x0,1"
else
  hyprctl keyword monitor "DP-1,2560x1440@180,1920x0,1.3"
  hyprctl keyword monitor "DP-2,1920x1080@60,0x0,1,mirror,DP-1"
fi
